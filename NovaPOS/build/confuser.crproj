<?xml version="1.0" encoding="utf-8"?>
<project baseDir="." outputDir="." xmlns="http://confuser.codeplex.com">
  <rule pattern="true" preset="normal" inherit="false">
    <protection id="rename">
      <argument name="renPublic" value="false" />
    </protection>
    <protection id="constants" />
    <protection id="ctrl flow" />
  </rule>
  <rule pattern="namespace('NovaPOS.Data.Migrations')" preset="none" inherit="false" />
  <module path="NovaPOS.dll" />
</project>
