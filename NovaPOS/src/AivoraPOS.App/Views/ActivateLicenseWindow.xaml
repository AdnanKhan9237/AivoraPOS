<Window x:Class="AivoraPOS.App.Views.ActivateLicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activate AivoraPOS License"
        Height="360"
        Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Activate License"
                   FontSize="22"
                   FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Margin="0,8,0,16"
                   Text="Enter your license key and business name to activate AivoraPOS on this machine."
                   TextWrapping="Wrap"
                   Foreground="#666" />

        <StackPanel Grid.Row="2">
            <TextBlock Text="Business name" Margin="0,0,0,4" />
            <TextBox Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,0,12" />
            <TextBlock Text="License key" Margin="0,0,0,4" />
            <TextBox Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,0,12" />
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#C0392B"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" />
            <Button Content="Activate"
                    Width="100"
                    Height="32"
                    Command="{Binding ActivateCommand}" />
        </StackPanel>
    </Grid>
</Window>
