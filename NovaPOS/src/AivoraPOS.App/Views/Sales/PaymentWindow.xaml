<Window x:Class="AivoraPOS.App.Views.Sales.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment"
        Height="560"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="OnKeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Payment" FontSize="22" FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Margin="0,16,0,8">
            <TextBlock Text="Total Due" Foreground="#666" />
            <TextBlock Text="{Binding TotalDue, StringFormat={}{0:C}}" FontSize="28" FontWeight="Bold" />
        </StackPanel>

        <ComboBox Grid.Row="2"
                  ItemsSource="{Binding PaymentMethods}"
                  SelectedItem="{Binding PaymentMethod}"
                  Margin="0,0,0,12" />

        <StackPanel Grid.Row="3">
            <TextBlock Text="Amount Received" Margin="0,0,0,4" />
            <TextBlock Text="{Binding AmountReceived, StringFormat={}{0:C}}" FontSize="24" Margin="0,0,0,8" />

            <UniformGrid Columns="3" Rows="4">
                <Button Content="7" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="7" />
                <Button Content="8" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="8" />
                <Button Content="9" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="9" />
                <Button Content="4" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="4" />
                <Button Content="5" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="5" />
                <Button Content="6" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="6" />
                <Button Content="1" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="1" />
                <Button Content="2" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="2" />
                <Button Content="3" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="3" />
                <Button Content="C" Margin="2" Command="{Binding ClearEntryCommand}" />
                <Button Content="0" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="0" />
                <Button Content="00" Margin="2" Command="{Binding AppendDigitCommand}" CommandParameter="00" />
            </UniformGrid>

            <TextBlock Text="{Binding Change, StringFormat=CHANGE: {0:C}}" FontSize="20" FontWeight="Bold" Foreground="#1F7A1F" Margin="0,12,0,0" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="#C0392B" Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="100" Height="36" Margin="0,0,8,0" Click="OnCancel" />
            <Button Content="Confirm" Width="100" Height="36" FontWeight="Bold" Click="OnConfirm" />
        </StackPanel>
    </Grid>
</Window>
