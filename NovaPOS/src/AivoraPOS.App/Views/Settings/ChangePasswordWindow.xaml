<Window x:Class="AivoraPOS.App.Views.Settings.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password"
        Height="320"
        Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="Change Password" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16" />
        <TextBlock Text="Current password" Foreground="{DynamicResource TextSecondaryBrush}" />
        <PasswordBox x:Name="CurrentBox" Height="32" Margin="0,4,0,12" PasswordChanged="OnCurrentChanged" />
        <TextBlock Text="New password" Foreground="{DynamicResource TextSecondaryBrush}" />
        <PasswordBox x:Name="NewBox" Height="32" Margin="0,4,0,12" PasswordChanged="OnNewChanged" />
        <TextBlock Text="Confirm new password" Foreground="{DynamicResource TextSecondaryBrush}" />
        <PasswordBox x:Name="ConfirmBox" Height="32" Margin="0,4,0,12" PasswordChanged="OnConfirmChanged" />
        <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource DangerBrush}" Margin="0,0,0,12" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
            <Button Content="Save" Width="90" Command="{Binding SaveCommand}" />
        </StackPanel>
    </StackPanel>
</Window>
