<Window x:Class="AivoraPOS.KeyGenerator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AivoraPOS Key Generator"
        Height="640"
        Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Generate License Keys"
                   FontSize="22"
                   FontWeight="SemiBold" />

        <Grid Grid.Row="1" Margin="0,20,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Customer name" Margin="0,0,0,4" />
                <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" Height="32" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                <TextBlock Text="Plan" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Plans}"
                          SelectedItem="{Binding SelectedPlan}"
                          Height="32" />
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                <TextBlock Text="Expiry date" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding ExpiryDate}" Height="32" />
            </StackPanel>

            <Button Grid.Column="3"
                    VerticalAlignment="Bottom"
                    Content="Generate Key"
                    Width="120"
                    Height="32"
                    Command="{Binding GenerateCommand}" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Generated key" FontWeight="SemiBold" />
            <DockPanel Grid.Row="1" Margin="0,8,0,16">
                <Button DockPanel.Dock="Right"
                        Margin="12,0,0,0"
                        Width="80"
                        Height="32"
                        Content="Copy"
                        Command="{Binding CopyCommand}" />
                <TextBox Text="{Binding GeneratedKey, Mode=OneWay}"
                         IsReadOnly="True"
                         Height="32"
                         VerticalContentAlignment="Center" />
            </DockPanel>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding History}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Generated" Binding="{Binding GeneratedAtUtc, StringFormat=g}" Width="160" />
                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                    <DataGridTextColumn Header="Plan" Binding="{Binding Plan}" Width="120" />
                    <DataGridTextColumn Header="Expires" Binding="{Binding ExpiresAtUtc, StringFormat=d}" Width="120" />
                    <DataGridTextColumn Header="License Key" Binding="{Binding LicenseKey}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
