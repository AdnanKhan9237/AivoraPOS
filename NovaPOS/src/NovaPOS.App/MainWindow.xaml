<Window x:Class="NovaPOS.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NovaPOS"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="NovaPOS"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="#444" />
        </StackPanel>

        <Border Grid.Row="1"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="Point of Sale"
                           FontSize="22"
                           FontWeight="Medium"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Solution scaffold initialized. Licensing, checkout, and reporting modules will be built next."
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Width="520"
                           TextAlignment="Center"
                           Foreground="#666" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
