<Window x:Class="NovaPOS.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:NovaPOS.App.Views.Shell"
        xmlns:vm="clr-namespace:NovaPOS.App.ViewModels"
        xmlns:salesVm="clr-namespace:NovaPOS.App.ViewModels.Sales"
        xmlns:productsVm="clr-namespace:NovaPOS.App.ViewModels.Products"
        xmlns:reportsVm="clr-namespace:NovaPOS.App.ViewModels.Reports"
        xmlns:settingsVm="clr-namespace:NovaPOS.App.ViewModels.Settings"
        xmlns:usersVm="clr-namespace:NovaPOS.App.ViewModels.Users"
        xmlns:sales="clr-namespace:NovaPOS.App.Views.Sales"
        xmlns:pages="clr-namespace:NovaPOS.App.Views.Pages"
        Title="NovaPOS"
        Height="800"
        Width="1360"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type salesVm:SalesViewModel}">
            <sales:SalesScreen />
        </DataTemplate>
        <DataTemplate DataType="{x:Type productsVm:ProductsViewModel}">
            <pages:ProductsPageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type reportsVm:ReportsViewModel}">
            <pages:ReportsPageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditLogViewModel}">
            <pages:AuditLogPageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type settingsVm:SettingsViewModel}">
            <pages:SettingsPageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type usersVm:UsersViewModel}">
            <pages:UsersPageView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="◆" FontSize="20" Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,8,0" />
                    <TextBlock Text="NovaPOS" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource HeaderForegroundBrush}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding BusinessName}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HeaderForegroundBrush}" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding UserDisplayName, StringFormat=User: {0}}"
                               Foreground="{DynamicResource HeaderSubtleForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Button Content="Logout"
                            Padding="12,4"
                            Command="{Binding LogoutCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Update banner -->
        <Border Grid.Row="1"
                Background="{DynamicResource AccentBrush}"
                Padding="12,6"
                Visibility="{Binding ShowUpdateBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DockPanel>
                <Button Content="Dismiss"
                        DockPanel.Dock="Right"
                        Padding="10,2"
                        Margin="8,0,0,0"
                        Command="{Binding DismissUpdateCommand}" />
                <Button Content="Update Now"
                        DockPanel.Dock="Right"
                        Padding="10,2"
                        Command="{Binding InstallUpdateCommand}" />
                <TextBlock Text="{Binding UpdateBannerText}"
                           Foreground="{DynamicResource AccentForegroundBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- License banner -->
        <Border Grid.Row="2"
                Background="{DynamicResource TrialBannerBrush}"
                Padding="12,6"
                Visibility="{Binding ShowLicenseBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DockPanel>
                <Button Content="Activate License"
                        DockPanel.Dock="Right"
                        Padding="10,2"
                        Command="{Binding ActivateLicenseCommand}" />
                <TextBlock Text="{Binding LicenseBannerText}"
                           Foreground="{DynamicResource WarningForegroundBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Body: nav + content -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource NavBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="8,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding NavigateCommand}"
                                    Margin="0,2"
                                    Padding="12,10"
                                    HorizontalContentAlignment="Left"
                                    Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{DynamicResource NavItemBrush}" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource NavItemActiveBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="🔒"
                                               Visibility="{Binding ShowLockedIcon, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <Border DockPanel.Dock="Right"
                                            Background="{DynamicResource DangerBrush}"
                                            CornerRadius="8"
                                            Padding="6,1"
                                            Margin="4,0,0,0"
                                            Visibility="{Binding ShowBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding BadgeText}"
                                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource NavItemForegroundBrush}" />
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Grid Grid.Column="1">
                <ContentControl Content="{Binding CurrentPage}" Margin="0" />
                <shell:LockOverlayView DataContext="{Binding LockOverlay}"
                                        Visibility="{Binding IsLocked, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Background="{DynamicResource StatusBarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <DockPanel>
                <Border DockPanel.Dock="Right"
                        Background="{DynamicResource AccentBrush}"
                        CornerRadius="10"
                        Padding="10,2"
                        Margin="8,0,0,0">
                    <TextBlock Text="{Binding LicensePillText}"
                               Foreground="{DynamicResource AccentForegroundBrush}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding LowStockStatusText}"
                           Foreground="{DynamicResource DangerBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="{Binding ShowLowStockStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Text="{Binding ConnectionStatus, StringFormat={}{0}}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />
                <TextBlock Text="{Binding TodaySalesText}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
