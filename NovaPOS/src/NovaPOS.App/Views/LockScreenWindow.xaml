<Window x:Class="NovaPOS.App.Views.LockScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NovaPOS - Sign In"
        Height="520"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="NovaPOS"
                   FontSize="28"
                   FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Margin="0,8,0,20"
                   Text="Sign in to continue"
                   Foreground="#666" />

        <StackPanel Grid.Row="2">
            <CheckBox Content="Manager / Admin sign-in"
                      IsChecked="{Binding IsManagerLogin}"
                      Margin="0,0,0,16" />

            <StackPanel Visibility="{Binding IsManagerLogin, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Username" Margin="0,0,0,4" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="32" Margin="0,0,0,12" />
                <TextBlock Text="Password" Margin="0,0,0,4" />
                <PasswordBox x:Name="ManagerPasswordBox" Height="32" Margin="0,0,0,12" PasswordChanged="OnManagerPasswordChanged" />
            </StackPanel>

            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsManagerLogin}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Cashier" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Cashiers}"
                          DisplayMemberPath="FullName"
                          SelectedItem="{Binding SelectedCashier}"
                          Height="32"
                          Margin="0,0,0,12" />
                <TextBlock Text="4-digit PIN" Margin="0,0,0,4" />
                <PasswordBox x:Name="PinPasswordBox" Height="32" MaxLength="4" PasswordChanged="OnPinPasswordChanged" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#C0392B"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Button Grid.Row="3"
                Content="Sign In"
                Height="36"
                Command="{Binding LoginCommand}" />
    </Grid>
</Window>
