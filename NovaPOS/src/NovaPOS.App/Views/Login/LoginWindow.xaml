<Window x:Class="NovaPOS.App.Views.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NovaPOS.App.Controls"
        Title="AivoraPOS — Sign In"
        Height="580"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="Assets/aivorapos.ico"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,12">
            <controls:BrandLogoView LogoWidth="90" LogoHeight="50"
                                    HorizontalAlignment="Center"
                                    FallbackForeground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="AivoraPOS"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Margin="0,0,0,20"
                   Text="Sign in to continue"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource TextSecondaryBrush}" />

        <StackPanel Grid.Row="2">
            <CheckBox Content="Manager / Admin sign-in"
                      IsChecked="{Binding IsManagerLogin}"
                      Margin="0,0,0,16" />

            <StackPanel Visibility="{Binding IsManagerLogin, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Username" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="32" Margin="0,0,0,12" />
                <TextBlock Text="Password" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <PasswordBox x:Name="ManagerPasswordBox" Height="32" Margin="0,0,0,12" PasswordChanged="OnManagerPasswordChanged" />
            </StackPanel>

            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsManagerLogin}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Cashier" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Cashiers}"
                          DisplayMemberPath="FullName"
                          SelectedItem="{Binding SelectedCashier}"
                          Height="32"
                          Margin="0,0,0,12" />
                <TextBlock Text="4-digit PIN" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <PasswordBox x:Name="PinPasswordBox" Height="32" MaxLength="4" PasswordChanged="OnPinPasswordChanged" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource DangerBrush}"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Button Grid.Row="3"
                Content="Sign In"
                Height="36"
                Command="{Binding LoginCommand}" />

        <TextBlock Grid.Row="4"
                   Text="Powered by Aivora Technologies"
                   FontSize="10"
                   Foreground="#888888"
                   HorizontalAlignment="Center"
                   Margin="0,16,0,0" />
    </Grid>
</Window>
