<UserControl x:Class="NovaPOS.App.Views.Pages.AuditLogPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Audit Log"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <DatePicker SelectedDate="{Binding StartDate}" Height="32" Margin="0,0,8,0" />
            <DatePicker Grid.Column="1" SelectedDate="{Binding EndDate}" Height="32" Margin="0,0,8,0" />
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding Users}"
                      DisplayMemberPath="FullName"
                      SelectedItem="{Binding SelectedUser}"
                      Height="32"
                      Margin="0,0,8,0" />
            <TextBox Grid.Column="3" Text="{Binding ActionFilter, UpdateSourceTrigger=PropertyChanged}" Height="32" Margin="0,0,8,0" />
            <Button Grid.Column="4" Content="Search" Width="90" Height="32" Command="{Binding SearchCommand}" />
        </Grid>
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="When" Binding="{Binding CreatedAt, StringFormat=g}" Width="160" />
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="180" />
                <DataGridTextColumn Header="Entity" Binding="{Binding EntityType}" Width="120" />
                <DataGridTextColumn Header="Entity Id" Binding="{Binding EntityId}" Width="120" />
                <DataGridTextColumn Header="Machine" Binding="{Binding MachineName}" Width="120" />
                <DataGridTextColumn Header="Details" Binding="{Binding NewValues}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
