<UserControl x:Class="NovaPOS.App.Views.Pages.ProductsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:products="clr-namespace:NovaPOS.App.Views.Products">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Products &amp; Inventory"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,12" />
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Products">
                <products:ProductListView DataContext="{Binding ProductList}" />
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Low Stock" VerticalAlignment="Center" />
                        <Border Background="{DynamicResource DangerBrush}"
                                CornerRadius="8"
                                Padding="6,1"
                                Margin="8,0,0,0"
                                Visibility="{Binding ShowLowStockBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding LowStockBadgeText}"
                                       Foreground="{DynamicResource AccentForegroundBrush}"
                                       FontSize="11"
                                       FontWeight="Bold" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <products:LowStockView DataContext="{Binding LowStock}" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
