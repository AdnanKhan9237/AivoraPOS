<UserControl x:Class="NovaPOS.App.Views.Pages.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="24" MaxWidth="520">
        <TextBlock Text="Settings"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,20" />

        <TextBlock Text="Appearance" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
        <CheckBox Content="Dark theme"
                  IsChecked="{Binding IsDarkTheme}"
                  Margin="0,8,0,20" />

        <TextBlock Text="Session"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Visibility="{Binding CanManageSession, Converter={StaticResource BooleanToVisibilityConverter}}" />
        <StackPanel Orientation="Horizontal" Margin="0,8,0,8"
                    Visibility="{Binding CanManageSession, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Idle lock after" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox Text="{Binding IdleTimeoutMinutes}" Width="50" Margin="8,0" Height="28" />
            <TextBlock Text="minutes" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
            <Button Content="Save" Margin="12,0,0,0" Padding="12,4" Command="{Binding SaveSessionTimeoutCommand}" />
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,12,0,0" />
    </StackPanel>
</UserControl>
