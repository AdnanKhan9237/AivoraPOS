<UserControl x:Class="NovaPOS.App.Views.Pages.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Settings"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,12" />

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedSectionIndex}">
            <!-- Business -->
            <TabItem Header="Business">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel MaxWidth="640">
                        <TextBlock Text="Business Name" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding BusinessName}" Height="32" Margin="0,4,0,12" />
                        <TextBlock Text="Address" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding BusinessAddress}" Height="32" Margin="0,4,0,12" />
                        <TextBlock Text="Phone" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding BusinessPhone}" Height="32" Margin="0,4,0,12" />
                        <DockPanel Margin="0,0,0,12">
                            <Button Content="Choose Logo" DockPanel.Dock="Right" Padding="12,4" Command="{Binding PickLogoCommand}" />
                            <TextBlock Text="{Binding LogoPath, TargetNullValue=No logo selected}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </DockPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Currency Symbol" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBox Text="{Binding CurrencySymbol}" Height="32" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Currency Position" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <ComboBox ItemsSource="{Binding CurrencyPositions}" SelectedItem="{Binding CurrencyPosition}" Height="32" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Default Tax Rate (%)" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding DefaultTaxRatePercent}" Height="32" Margin="0,4,0,12" />
                        <Button Content="Save Business Info" HorizontalAlignment="Left" Padding="14,6" Command="{Binding SaveBusinessCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Receipt -->
            <TabItem Header="Receipt">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel MaxWidth="640">
                        <TextBlock Text="Header Text" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding ReceiptHeader}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4,0,12" />
                        <TextBlock Text="Footer Text" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding ReceiptFooter}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4,0,12" />
                        <CheckBox Content="Show logo on receipt" IsChecked="{Binding ShowLogoOnReceipt}" Margin="0,0,0,8" />
                        <CheckBox Content="Auto-print after sale" IsChecked="{Binding AutoPrintReceipt}" Margin="0,0,0,12" />
                        <TextBlock Text="Default Printer" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{Binding InstalledPrinters}" Text="{Binding SelectedPrinter}" IsEditable="True" Height="32" Margin="0,4,0,12" />
                        <TextBlock Text="Receipt Width" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{Binding ReceiptWidths}" SelectedItem="{Binding ReceiptWidth}" Height="32" Margin="0,4,0,12" />
                        <Button Content="Save Receipt Settings" HorizontalAlignment="Left" Padding="14,6" Command="{Binding SaveReceiptCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- POS -->
            <TabItem Header="POS Behavior">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel MaxWidth="640">
                        <TextBlock Text="Idle lock timeout (minutes, 0 = never)" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{Binding IdleTimeoutOptions}" SelectedItem="{Binding IdleLockTimeoutMinutes}" Height="32" Margin="0,4,0,12" />
                        <CheckBox Content="Require manager approval for any discount" IsChecked="{Binding RequireManagerForDiscount}" Margin="0,0,0,8" />
                        <CheckBox Content="Allow negative stock sales" IsChecked="{Binding AllowNegativeStock}" Margin="0,0,0,8" />
                        <TextBlock Text="Default Payment Method" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,4" />
                        <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding DefaultPaymentMethod}" Height="32" Margin="0,0,0,12" />
                        <CheckBox Content="Sound on sale complete" IsChecked="{Binding SoundOnSaleComplete}" Margin="0,0,0,12" />
                        <TextBlock Text="Appearance" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,8" />
                        <CheckBox Content="Dark theme" IsChecked="{Binding IsDarkTheme}" Margin="0,0,0,12" />
                        <Button Content="Save POS Settings" HorizontalAlignment="Left" Padding="14,6" Command="{Binding SavePosBehaviorCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Users -->
            <TabItem Header="Users" Visibility="{Binding CanManageUsers, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Add User" Padding="12,4" Margin="0,0,8,0" Command="{Binding AddUserCommand}" />
                        <Button Content="Edit User" Padding="12,4" Margin="0,0,8,0" Command="{Binding EditUserCommand}" CommandParameter="{Binding SelectedUser}" />
                        <Button Content="Reset PIN" Padding="12,4" Margin="0,0,8,0" Command="{Binding ResetPinCommand}" CommandParameter="{Binding SelectedUser}" />
                        <Button Content="Deactivate" Padding="12,4" Command="{Binding DeactivateUserCommand}" CommandParameter="{Binding SelectedUser}" />
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*" />
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="90" />
                            <DataGridTextColumn Header="Last Login" Binding="{Binding LastLoginText}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="2" Content="Change My Password" HorizontalAlignment="Left" Margin="0,12,0,0" Padding="12,4" Command="{Binding ChangeOwnPasswordCommand}" />
                </Grid>
            </TabItem>

            <!-- License -->
            <TabItem Header="License">
                <StackPanel Margin="8" MaxWidth="640">
                    <TextBlock Text="{Binding LicensePlanName, StringFormat=Plan: {0}}" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding LicenseExpiryText, StringFormat=Expires: {0}}" Margin="0,4,0,4" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding LicensedBusinessName, StringFormat=Licensed to: {0}}" Margin="0,0,0,4" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding MachineId, StringFormat=Machine ID: {0}}" TextWrapping="Wrap" Margin="0,0,0,16" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="Business Name" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding LicenseBusinessNameInput}" Height="32" Margin="0,4,0,12" />
                    <TextBlock Text="License Key" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBox Text="{Binding LicenseKeyInput}" Height="32" Margin="0,4,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Activate License" Padding="12,4" Margin="0,0,8,0" Command="{Binding ActivateLicenseCommand}" />
                        <Button Content="Transfer License" Padding="12,4" Margin="0,0,8,0" Command="{Binding TransferLicenseCommand}" />
                        <Button Content="Purchase" Padding="12,4" Command="{Binding OpenPurchasePageCommand}" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Data -->
            <TabItem Header="Data" Visibility="{Binding CanManageData, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Margin="8" MaxWidth="640">
                    <Button Content="Backup Database" Padding="12,6" HorizontalAlignment="Left" Command="{Binding BackupDatabaseCommand}" />
                    <Button Content="Restore Database" Padding="12,6" HorizontalAlignment="Left" Margin="0,8,0,0" Command="{Binding RestoreDatabaseCommand}" />
                    <Button Content="Export All Data (CSV)" Padding="12,6" HorizontalAlignment="Left" Margin="0,8,0,0"
                            IsEnabled="{Binding CanExportData}" Command="{Binding ExportDataCsvCommand}" />
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <TextBlock Text="Clear audit logs older than" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{Binding AuditRetentionMonthOptions}" SelectedItem="{Binding SelectedAuditRetentionMonths}" Width="60" Margin="8,0" />
                        <TextBlock Text="months" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Button Content="Clear" Margin="12,0,0,0" Padding="12,4" Command="{Binding ClearOldLogsCommand}" />
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
    </Grid>
</UserControl>
