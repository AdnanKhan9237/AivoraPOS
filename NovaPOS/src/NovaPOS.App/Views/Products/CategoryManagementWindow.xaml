<Window x:Class="NovaPOS.App.Views.Products.CategoryManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Categories"
        Height="520"
        Width="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Category Management" FontSize="20" FontWeight="SemiBold" />

        <DockPanel Grid.Row="1" Margin="0,16,0,16">
            <Button Content="Add" DockPanel.Dock="Right" Width="80" Command="{Binding AddCommand}" />
            <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}" Height="32" Margin="0,0,8,0" />
        </DockPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Categories}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                <DataGridTextColumn Header="Active Products" Binding="{Binding ActiveProductCount}" Width="120" IsReadOnly="True" />
                <DataGridTemplateColumn Header="Actions" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Save" Margin="0,0,4,0" Padding="8,2"
                                        Command="{Binding DataContext.RenameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Delete" Padding="8,2"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <Button Content="Close" DockPanel.Dock="Right" Width="90" Command="{Binding CloseCommand}" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="#C62828" VerticalAlignment="Center" />
        </DockPanel>
    </Grid>
</Window>
