<Window x:Class="NovaPOS.App.Views.Products.InventoryHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory History"
        Height="520"
        Width="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Inventory History" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" Margin="0,4,0,0" />
            <TextBlock Text="{Binding ProductSku, StringFormat=SKU: {0}}" Foreground="#555" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Movements}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="When" Binding="{Binding CreatedAt, StringFormat=g}" Width="150" />
                <DataGridTextColumn Header="Type" Binding="{Binding MovementType}" Width="120" />
                <DataGridTextColumn Header="Before" Binding="{Binding QuantityBefore}" Width="70" />
                <DataGridTextColumn Header="Change" Binding="{Binding QuantityChange}" Width="70" />
                <DataGridTextColumn Header="After" Binding="{Binding QuantityAfter}" Width="70" />
                <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="Close" Width="90" HorizontalAlignment="Right" Margin="0,16,0,0"
                Command="{Binding CloseCommand}" />
    </Grid>
</Window>
