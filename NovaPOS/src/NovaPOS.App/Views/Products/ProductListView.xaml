<UserControl x:Class="NovaPOS.App.Views.Products.ProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:NovaPOS.Core.Enums;assembly=NovaPOS.Core">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="StatusFilters" MethodName="GetValues" ObjectType="{x:Type enums:ProductStatusFilter}" />
        <ObjectDataProvider x:Key="StockFilters" MethodName="GetValues" ObjectType="{x:Type enums:StockLevelFilter}" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Add Product" Padding="12,6" Margin="0,0,8,0" Command="{Binding AddCommand}" />
            <Button Content="Edit" Padding="12,6" Margin="0,0,8,0" Command="{Binding EditCommand}" />
            <Button Content="Deactivate" Padding="12,6" Margin="0,0,8,0" Command="{Binding DeleteCommand}" />
            <Button Content="Import CSV" Padding="12,6" Margin="0,0,8,0"
                    IsEnabled="{Binding CanImportCsv}"
                    Command="{Binding ImportCsvCommand}" />
            <Button Content="Categories" Padding="12,6" Command="{Binding ManageCategoriesCommand}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     Tag="Search name, SKU, or barcode..." />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding FilterCategory}"
                      DisplayMemberPath="Name"
                      Height="32"
                      Margin="0,0,8,0" />
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding FilterStatus}"
                      Height="32"
                      Margin="0,0,8,0" />
            <ComboBox Grid.Column="3"
                      ItemsSource="{Binding StockLevelOptions}"
                      SelectedItem="{Binding FilterStockLevel}"
                      Height="32" />
        </Grid>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                    <MenuItem Header="View History" Command="{Binding DataContext.ViewHistoryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                    <MenuItem Header="Adjust Stock" Command="{Binding DataContext.AdjustStockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                    <MenuItem Header="Deactivate" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="110" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" MinWidth="160" />
                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="120" />
                <DataGridTextColumn Header="Price" Binding="{Binding SalePrice, StringFormat=C}" Width="90" />
                <DataGridTemplateColumn Header="Stock" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StockQuantity}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{Binding StockLevelKey, Converter={StaticResource StockLevelToBrushConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="First" Width="60" Margin="0,0,4,0" Command="{Binding FirstPageCommand}" />
                <Button Content="Prev" Width="60" Margin="0,0,4,0" Command="{Binding PreviousPageCommand}" />
                <Button Content="Next" Width="60" Margin="0,0,4,0" Command="{Binding NextPageCommand}" />
                <Button Content="Last" Width="60" Command="{Binding LastPageCommand}" />
            </StackPanel>
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding CurrentPage, StringFormat=Page {0}}"
                       Margin="0,0,12,0" />
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding TotalPages, StringFormat=of {0}}"
                       Margin="0,0,12,0" />
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding TotalCount, StringFormat=({0} products)}" />
        </DockPanel>
    </Grid>
</UserControl>
