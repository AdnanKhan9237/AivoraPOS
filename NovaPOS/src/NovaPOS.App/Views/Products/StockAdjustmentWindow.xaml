<Window x:Class="NovaPOS.App.Views.Products.StockAdjustmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adjust Stock"
        Height="420"
        Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="24">
        <TextBlock Text="Adjust Stock" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
        <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" />
        <TextBlock Text="{Binding CurrentStock, StringFormat=Current stock: {0}}" Margin="0,4,0,16" Foreground="#555" />

        <TextBlock Text="Reason" />
        <ComboBox ItemsSource="{Binding Reasons}"
                  SelectedItem="{Binding SelectedReason}"
                  Height="32"
                  Margin="0,4,0,12" />

        <CheckBox Content="Use +/- adjustment instead of new quantity"
                  IsChecked="{Binding UseAdjustmentMode}"
                  Margin="0,0,0,12" />

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="New Quantity" />
                <TextBox Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}"
                         Height="32"
                         Margin="0,4,0,0"
                         IsEnabled="{Binding UseAdjustmentMode, Converter={StaticResource InverseBooleanConverter}}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="Adjustment (+/-)" />
                <TextBox Text="{Binding AdjustmentDelta, UpdateSourceTrigger=PropertyChanged}"
                         Height="32"
                         Margin="0,4,0,0"
                         IsEnabled="{Binding UseAdjustmentMode}" />
            </StackPanel>
        </Grid>

        <TextBlock Text="Notes" />
        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                 Height="72"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Margin="0,4,0,12" />

        <TextBlock Text="{Binding ValidationMessage}" Foreground="#C62828" Margin="0,0,0,12" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
            <Button Content="Save" Width="90" IsDefault="True" Command="{Binding SaveCommand}" />
        </StackPanel>
    </StackPanel>
</Window>
