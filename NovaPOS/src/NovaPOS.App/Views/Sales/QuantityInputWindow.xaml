<Window x:Class="NovaPOS.App.Views.Sales.QuantityInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter Quantity"
        Height="180"
        Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="OnKeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Quantity" />
        <TextBox x:Name="QuantityBox" Grid.Row="1" Height="36" Margin="0,8,0,16" FontSize="18" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="OnCancel" />
            <Button Content="OK" Width="90" Click="OnOk" />
        </StackPanel>
    </Grid>
</Window>
