<UserControl x:Class="NovaPOS.App.Views.Sales.SalesScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sales="clr-namespace:NovaPOS.App.ViewModels.Sales"
             mc:Ignorable="d"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown">
    <UserControl.InputBindings>
        <KeyBinding Key="F2" Command="{Binding FocusSearchCommand}" />
        <KeyBinding Key="F4" Command="{Binding QuickAddBySkuCommand}" />
        <KeyBinding Key="F9" Command="{Binding ApplyDiscountCommand}" />
        <KeyBinding Key="F12" Command="{Binding CheckoutCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Row="0"
                     Height="44"
                     Margin="0,0,0,8"
                     FontSize="18"
                     Padding="12,8"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="OnSearchBoxKeyDown" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <CheckBox Content="Show out of stock"
                          IsChecked="{Binding ShowOutOfStock}"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0" />
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#666" />
            </StackPanel>

            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding SelectedCategory}"
                     BorderThickness="0"
                     Background="Transparent"
                     Margin="0,0,0,8">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type sales:CategoryVm}">
                        <Border Padding="12,6" Margin="0,0,8,0" CornerRadius="4" Background="#E8EEF4">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListBox Grid.Row="3"
                     ItemsSource="{Binding DisplayedProducts}"
                     BorderBrush="#DDD"
                     BorderThickness="1"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type sales:ProductTileVm}">
                        <Button Width="160" Height="110" Margin="4" Padding="8"
                                Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding IsOutOfStock, Converter={StaticResource InverseBooleanConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Opacity" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                            <Setter Property="Opacity" Value="0.45" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" MaxHeight="40" />
                                <TextBlock Text="{Binding PriceDisplay}" FontSize="16" FontWeight="Bold" Margin="0,6,0,0" HorizontalAlignment="Center" />
                                <Border HorizontalAlignment="Center" Margin="0,6,0,0" Padding="8,2" CornerRadius="10" Background="#D5F5E3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#D5F5E3" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                    <Setter Property="Background" Value="#FADBD8" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                                    <Setter Property="Background" Value="#E5E7E9" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StockDisplay}" FontSize="11" />
                                </Border>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <GridSplitter Grid.Column="1" Width="8" />

        <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Cart" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding CartItems}"
                         BorderThickness="0"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type sales:CartItemVm}">
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Button Content="-" Width="28" Height="28"
                                                    Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="{Binding Quantity}" MinWidth="36" Height="28" Margin="4,0"
                                                    Command="{Binding DataContext.PromptQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="+" Width="28" Height="28"
                                                    Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:C}}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#666" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding LineTotalDisplay}" FontWeight="SemiBold" />
                                        <Button Content="×" Width="24" Height="24" Margin="0,6,0,0"
                                                Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="0,12,0,12">
                    <Grid Margin="0,2"><TextBlock Text="Subtotal" /><TextBlock Text="{Binding SubTotal, StringFormat={}{0:C}}" HorizontalAlignment="Right" /></Grid>
                    <Grid Margin="0,2"><TextBlock Text="Tax" /><TextBlock Text="{Binding TaxAmount, StringFormat={}{0:C}}" HorizontalAlignment="Right" /></Grid>
                    <Grid Margin="0,2"><TextBlock Text="Discount" /><TextBlock Text="{Binding DiscountAmount, StringFormat={}{0:C}}" HorizontalAlignment="Right" /></Grid>
                    <Grid Margin="0,8,0,0">
                        <TextBlock Text="TOTAL" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C}}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Content="CLEAR" Height="44" Margin="0,0,4,0" Command="{Binding ClearCartCommand}" />
                    <Button Grid.Column="1" Content="CHECKOUT" Height="44" Margin="4,0,0,0" FontWeight="Bold" Background="#1F4E79" Foreground="White" Command="{Binding CheckoutCommand}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
