<Window x:Class="NovaPOS.App.Views.Settings.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User"
        Height="420"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <StackPanel Margin="24">
        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Add User" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Text" Value="Edit User" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Text="Full Name" Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBox Text="{Binding FullName}" Height="32" Margin="0,4,0,12" />
        <TextBlock Text="Username" Foreground="{DynamicResource TextSecondaryBrush}"
                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}}" />
        <TextBox Text="{Binding Username}" Height="32" Margin="0,4,0,12"
                 Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}}" />
        <TextBlock Text="Role" Foreground="{DynamicResource TextSecondaryBrush}" />
        <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" Height="32" Margin="0,4,0,12" />
        <TextBlock Text="PIN (4 digits)" Foreground="{DynamicResource TextSecondaryBrush}"
                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}}" />
        <PasswordBox x:Name="PinBox" Height="32" Margin="0,4,0,12" MaxLength="4"
                     Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}}"
                     PasswordChanged="OnPinChanged" />
        <TextBlock Text="Password" Foreground="{DynamicResource TextSecondaryBrush}"
                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}}" />
        <PasswordBox x:Name="PasswordBox" Height="32" Margin="0,4,0,12"
                     Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}}"
                     PasswordChanged="OnPasswordChanged" />
        <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource DangerBrush}" Margin="0,0,0,12" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
            <Button Content="Save" Width="90" Command="{Binding SaveCommand}" />
        </StackPanel>
    </StackPanel>
</Window>
