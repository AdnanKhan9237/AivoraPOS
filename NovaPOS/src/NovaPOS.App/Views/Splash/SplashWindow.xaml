<Window x:Class="NovaPOS.App.Views.Splash.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NovaPOS.App.Controls"
        Title="AivoraPOS"
        Width="480"
        Height="300"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#0A0F2C"
        AllowsTransparency="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:BrandLogoView Grid.Row="0"
                                LogoWidth="220"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center" />

        <ProgressBar Grid.Row="1"
                     Height="4"
                     Margin="40,0,40,12"
                     IsIndeterminate="True"
                     Foreground="#4FC3F7"
                     Background="#1A2347" />

        <TextBlock Grid.Row="2"
                   x:Name="CopyrightText"
                   FontSize="10"
                   Foreground="#888888"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16" />
    </Grid>
</Window>
