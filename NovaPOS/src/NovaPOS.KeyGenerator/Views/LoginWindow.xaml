<Window x:Class="NovaPOS.KeyGenerator.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NovaPOS Key Generator - Login"
        Height="280"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="NovaPOS License Key Generator"
                   FontSize="20"
                   FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Margin="0,8,0,16"
                   Text="Enter your master password to continue."
                   Foreground="#666" />

        <StackPanel Grid.Row="2">
            <PasswordBox x:Name="PasswordBox"
                           Height="32"
                           Margin="0,0,0,12" />
            <TextBlock x:Name="ErrorText"
                       Foreground="#C0392B"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Visibility="Collapsed" />
            <Button Content="Unlock"
                    Height="36"
                    Click="OnUnlockClick" />
        </StackPanel>
    </Grid>
</Window>
